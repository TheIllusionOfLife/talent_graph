# Database
DATABASE_URL=postgresql+asyncpg://talent_graph:talent_graph@localhost:5432/talent_graph

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=talent_graph

# API
API_KEY=change-me-in-production
API_HOST=0.0.0.0
API_PORT=8000

# MLX LLM server (local Qwen 3.5 35B via mlx_lm.server)
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=mlx-community/Qwen3.5-35B-A3B-4bit
LLM_TIMEOUT=60

# Embedding model (downloaded from HuggingFace on first use)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Raw JSON storage
RAW_DATA_DIR=data/raw

# OpenAlex
OPENALEX_EMAIL=your@email.com

# GitHub (required for >60 req/hr)
GITHUB_TOKEN=ghp_your_token_here

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
